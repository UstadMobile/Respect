        <service
            android:name="world.respect.xapi.ipc.server.XapiIpcService"
            android:exported="true"
            tools:ignore="ExportedService">

            <intent-filter>
                <action android:name="org.openeel.action.xapioveripc" />
            </intent-filter>
        </service>

    </application>
</manifest>
